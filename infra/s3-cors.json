{
  "CORSRules": [
    {
      "AllowedOrigins": [
        "http://localhost:3000",
        "https://localhost:3000",
        "https://*.vercel.app"
      ],
      "AllowedMethods": ["GET", "HEAD", "PUT"],
      "AllowedHeaders": ["*"],
      "ExposeHeaders": ["ETag", "Content-Length", "Content-Type"],
      "MaxAgeSeconds": 3600
    }
  ]
}
